# =============================================================================
#  Variables de entorno — Sitio personal de Mario Cepeda
# =============================================================================
#  Copia este archivo como `.env.local` dentro de CADA app (apps/propuesta-x/)
#  o configúralas en el panel de Vercel por proyecto.
#
#  IMPORTANTE: las webs públicas FUNCIONAN sin estas variables (usan datos de
#  ejemplo embebidos). Configúralas para activar Supabase (admin + datos reales).
# -----------------------------------------------------------------------------

# URL del proyecto Supabase (Project Settings -> API -> Project URL)
NEXT_PUBLIC_SUPABASE_URL="https://tu-proyecto.supabase.co"

# Clave pública anónima (Project Settings -> API -> anon public)
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOi..."

# Clave service_role — SOLO servidor. Úsala para el script de seed.
# NUNCA la expongas en el cliente ni la subas a git.
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOi..."

# URL pública del sitio (para metadata SEO, sitemap y Open Graph)
NEXT_PUBLIC_SITE_URL="https://mariocepeda.co"
